<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nodes Management | Smart Lily</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/mema-redesign/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg neo-nav mb-5">
        <div class="container">
            <a class="nav-logo" href="/">
                <i class="fas fa-lily me-2 text-danger"></i>SMART LILY
            </a>
            <div class="ms-auto d-flex align-items-center">
                <ul class="navbar-nav flex-row gap-4">
                    <li class="nav-item">
                        <a class="nav-link" href="/">HUB</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-primary" href="/topics">NODES</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/automation">FLOWS</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row mb-5">
            <div class="col-md-12">
                <h1 class="display-3 mb-0">NODES & TOPICS</h1>
                <p class="text-secondary fw-800 mt-2">HIERARCHICAL NAMESPACE MANAGEMENT</p>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="neo-card">
                    <div class="neo-card-header d-flex justify-content-between align-items-center">
                        <span>ACTIVE NAMESPACES</span>
                        <button class="btn btn-sm btn-outline-light rounded-pill px-3" onclick="refreshTopics()">REFRESH</button>
                    </div>
                    <div class="neo-card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="stat-label">
                                    <tr>
                                        <th>TOPIC PATH</th>
                                        <th>SUBSCRIBERS</th>
                                        <th>LAST PAYLOAD</th>
                                        <th>ACTIONS</th>
                                    </tr>
                                </thead>
                                <tbody id="topics-table-body" class="fw-600">
                                    <!-- Populated via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const tableBody = document.getElementById('topics-table-body');

        socket.on('initial_state', (data) => {
            renderTopics(data.topics);
        });

        socket.on('topic_update', (update) => {
            // Simple approach: re-request or update specific row
            refreshTopics();
        });

        function refreshTopics() {
            fetch('/api/topics')
                .then(res => res.json())
                .then(topics => renderTopics(topics));
        }

        function renderTopics(topics) {
            tableBody.innerHTML = topics.map(t => `
                <tr>
                    <td><code class="text-primary fw-800">${t.topic}</code></td>
                    <td><span class="badge bg-dark rounded-pill">${t.subscribers}</span></td>
                    <td><small class="text-muted font-monospace">${JSON.stringify(t.lastMessage) || '--'}</small></td>
                    <td>
                        <button class="btn btn-sm btn-dark rounded-pill px-3 fw-800" onclick="deleteTopic('${encodeURIComponent(t.topic)}')">FLUSH</button>
                    </td>
                </tr>
            `).join('');
        }

        function deleteTopic(topic) {
            if(confirm('Delete retained message for this topic?')) {
                fetch(\`/api/topics/\${topic}\`, { method: 'DELETE' })
                    .then(() => refreshTopics());
            }
        }

        refreshTopics();
    </script>
</body>
</html>
