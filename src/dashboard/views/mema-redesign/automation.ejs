<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flows & Automation | Smart Lily</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/mema-redesign/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg neo-nav mb-5">
        <div class="container">
            <a class="nav-logo" href="/">
                <i class="fas fa-lily me-2 text-danger"></i>SMART LILY
            </a>
            <div class="ms-auto d-flex align-items-center">
                <ul class="navbar-nav flex-row gap-4">
                    <li class="nav-item"><a class="nav-link" href="/">HUB</a></li>
                    <li class="nav-item"><a class="nav-link" href="/topics">NODES</a></li>
                    <li class="nav-item"><a class="nav-link text-primary" href="/automation">FLOWS</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row mb-5">
            <div class="col-md-8">
                <h1 class="display-3 mb-0">FLOWS</h1>
                <p class="text-secondary fw-800 mt-2">AUTONOMOUS LOGIC ENGINE</p>
            </div>
            <div class="col-md-4 text-md-end pt-4">
                <button class="neo-btn neo-btn-primary" data-bs-toggle="modal" data-bs-target="#addRuleModal">NEW RULE</button>
            </div>
        </div>

        <div class="row" id="rules-container">
            <!-- Automation cards populated here -->
        </div>
    </div>

    <!-- Simple Add Rule Modal -->
    <div class="modal fade" id="addRuleModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" style="border-radius: 28px; border: 3px solid black;">
                <div class="modal-header border-0 p-4">
                    <h5 class="fw-800">CREATE NEW FLOW</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="rule-form">
                        <div class="mb-4">
                            <label class="stat-label">RULE NAME</label>
                            <input type="text" class="form-control rounded-pill border-2 border-dark px-4" id="rule-name" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="stat-label">IF TOPIC</label>
                                <input type="text" class="form-control rounded-pill border-2 border-dark px-4" id="cond-topic" placeholder="sensors/temp" required>
                            </div>
                            <div class="col-md-3 mb-4">
                                <label class="stat-label">OP</label>
                                <select class="form-select rounded-pill border-2 border-dark px-4" id="cond-op">
                                    <option value=">">></option>
                                    <option value="<"><</option>
                                    <option value="==">==</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-4">
                                <label class="stat-label">VALUE</label>
                                <input type="text" class="form-control rounded-pill border-2 border-dark px-4" id="cond-val" required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="stat-label">THEN PUBLISH TO</label>
                            <input type="text" class="form-control rounded-pill border-2 border-dark px-4" id="action-topic" placeholder="actuators/fan" required>
                        </div>
                        <div class="mb-4">
                            <label class="stat-label">PAYLOAD</label>
                            <input type="text" class="form-control rounded-pill border-2 border-dark px-4" id="action-payload" placeholder='{"state": "on"}' required>
                        </div>
                        <button type="submit" class="neo-btn neo-btn-primary w-100">SAVE FLOW</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function loadRules() {
            fetch('/api/automation/rules')
                .then(res => res.json())
                .then(rules => {
                    const container = document.getElementById('rules-container');
                    container.innerHTML = rules.map(r => `
                        <div class="col-md-6 mb-4">
                            <div class="neo-card">
                                <div class="neo-card-header d-flex justify-content-between">
                                    <span>${r.name.toUpperCase()}</span>
                                    <span class="badge ${r.enabled ? 'bg-success' : 'bg-secondary'} rounded-pill">${r.enabled ? 'ACTIVE' : 'DISABLED'}</span>
                                </div>
                                <div class="neo-card-body">
                                    <div class="small fw-800 text-secondary mb-2">TRIGGER</div>
                                    <p class="fw-600 mb-3">If <code class="text-primary">${r.conditions[0].topic}</code> ${r.conditions[0].operator} <code>${r.conditions[0].value}</code></p>
                                    <div class="small fw-800 text-secondary mb-2">ACTION</div>
                                    <p class="fw-600">Publish to <code class="text-danger">${r.actions[0].topic}</code></p>
                                    <hr class="border-2">
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-dark rounded-pill px-3 fw-800" onclick="deleteRule('${r.id}')">DELETE</button>
                                        <button class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-800" onclick="toggleRule('${r.id}', ${r.enabled})">${r.enabled ? 'DISABLE' : 'ENABLE'}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                });
        }

        function deleteRule(id) {
            if(confirm('Delete this flow?')) {
                fetch(\`/api/automation/rules/\${id}\`, { method: 'DELETE' }).then(() => loadRules());
            }
        }

        function toggleRule(id, current) {
            const action = current ? 'disable' : 'enable';
            fetch(\`/api/automation/rules/\${id}/\${action}\`, { method: 'POST' }).then(() => loadRules());
        }

        document.getElementById('rule-form').onsubmit = (e) => {
            e.preventDefault();
            const rule = {
                name: document.getElementById('rule-name').value,
                conditions: [{
                    topic: document.getElementById('cond-topic').value,
                    operator: document.getElementById('cond-op').value,
                    value: document.getElementById('cond-val').value
                }],
                actions: [{
                    type: 'publish',
                    topic: document.getElementById('action-topic').value,
                    payload: document.getElementById('action-payload').value
                }]
            };
            fetch('/api/automation/rules', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(rule)
            }).then(() => {
                const modal = bootstrap.Modal.getInstance(document.getElementById('addRuleModal'));
                modal.hide();
                loadRules();
            });
        };

        loadRules();
    </script>
</body>
</html>
