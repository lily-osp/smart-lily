<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Webhooks | Smart Lily</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/mema-redesign/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg neo-nav mb-5">
        <div class="container">
            <a class="nav-logo" href="/">
                <i class="fas fa-lily me-2 text-danger"></i>SMART LILY
            </a>
            <div class="ms-auto">
                <ul class="navbar-nav flex-row gap-4">
                    <li class="nav-item"><a class="nav-link" href="/">HUB</a></li>
                    <li class="nav-item"><a class="nav-link" href="/topics">NODES</a></li>
                    <li class="nav-item"><a class="nav-link" href="/automation">FLOWS</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row mb-5">
            <div class="col-md-8">
                <h1 class="display-3 mb-0">WEBHOOKS</h1>
                <p class="text-secondary fw-800 mt-2">EXTERNAL API INTEGRATIONS</p>
            </div>
            <div class="col-md-4 text-md-end pt-4">
                <button class="neo-btn neo-btn-primary" data-bs-toggle="modal" data-bs-target="#addWebhookModal">ADD HOOK</button>
            </div>
        </div>

        <div class="row" id="webhooks-container">
            <!-- Webhook cards populated here -->
        </div>
    </div>

    <!-- Add Webhook Modal -->
    <div class="modal fade" id="addWebhookModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content" style="border-radius: 28px; border: 3px solid black;">
                <div class="modal-header border-0 p-4">
                    <h5 class="fw-800">NEW WEBHOOK</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="webhook-form">
                        <div class="mb-4">
                            <label class="stat-label">FRIENDLY NAME</label>
                            <input type="text" class="form-control rounded-pill border-2 border-dark px-4" id="hook-name" placeholder="Discord Alert" required>
                        </div>
                        <div class="mb-4">
                            <label class="stat-label">TARGET URL</label>
                            <input type="url" class="form-control rounded-pill border-2 border-dark px-4" id="hook-url" placeholder="https://api.provider.com/webhook" required>
                        </div>
                        <div class="mb-4">
                            <label class="stat-label">EVENTS</label>
                            <div class="form-check fw-600">
                                <input class="form-check-input" type="checkbox" value="message" id="event-msg" checked>
                                <label class="form-check-label" for="event-msg">On MQTT Message</label>
                            </div>
                            <div class="form-check fw-600">
                                <input class="form-check-input" type="checkbox" value="connection" id="event-conn">
                                <label class="form-check-label" for="event-conn">On Client Connect</label>
                            </div>
                        </div>
                        <button type="submit" class="neo-btn neo-btn-primary w-100">SAVE WEBHOOK</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function loadWebhooks() {
            fetch('/api/webhooks')
                .then(res => res.json())
                .then(hooks => {
                    const container = document.getElementById('webhooks-container');
                    container.innerHTML = hooks.map(h => `
                        <div class="col-md-6 mb-4">
                            <div class="neo-card">
                                <div class="neo-card-header d-flex justify-content-between">
                                    <span>${h.name.toUpperCase()}</span>
                                    <span class="badge ${h.enabled ? 'bg-success' : 'bg-secondary'} rounded-pill">${h.enabled ? 'ACTIVE' : 'DISABLED'}</span>
                                </div>
                                <div class="neo-card-body">
                                    <div class="stat-label">ENDPOINT</div>
                                    <div class="text-truncate fw-600 mb-3 font-monospace small">${h.url}</div>
                                    <div class="stat-label">TRIGGERS</div>
                                    <div class="d-flex gap-2 mb-4">
                                        ${h.events.map(e => `<span class="badge bg-dark rounded-pill">${e}</span>`).join('')}
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-dark rounded-pill px-3 fw-800" onclick="deleteHook('${h.id}')">DELETE</button>
                                        <button class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-800" onclick="toggleHook('${h.id}', ${h.enabled})">${h.enabled ? 'OFF' : 'ON'}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                });
        }

        function deleteHook(id) {
            if(confirm('Delete this webhook?')) {
                fetch(\`/api/webhooks/\${id}\`, { method: 'DELETE' }).then(() => loadWebhooks());
            }
        }

        function toggleHook(id, current) {
            const action = current ? 'disable' : 'enable';
            fetch(\`/api/webhooks/\${id}/\${action}\`, { method: 'POST' }).then(() => loadWebhooks());
        }

        document.getElementById('webhook-form').onsubmit = (e) => {
            e.preventDefault();
            const events = [];
            if(document.getElementById('event-msg').checked) events.push('message');
            if(document.getElementById('event-conn').checked) events.push('connection');

            const hook = {
                name: document.getElementById('hook-name').value,
                url: document.getElementById('hook-url').value,
                events: events
            };
            fetch('/api/webhooks', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(hook)
            }).then(() => {
                bootstrap.Modal.getInstance(document.getElementById('addWebhookModal')).hide();
                loadWebhooks();
            });
        };

        loadWebhooks();
    </script>
</body>
</html>
